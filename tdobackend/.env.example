# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tallerdeotto.com,www.tallerdeotto.com,127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://tallerdeotto.com,https://www.tallerdeotto.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://tallerdeotto.com,https://www.tallerdeotto.com
DJANGO_LANGUAGE_CODE=es-ar
DJANGO_TIME_ZONE=America/Argentina/Buenos_Aires
DJANGO_STATIC_ROOT=/var/www/tallerdeotto/staticfiles
DJANGO_MEDIA_ROOT=/var/www/tallerdeotto/media
DJANGO_MEDIA_URL=/media/
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=2592000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SESSION_COOKIE_SAMESITE=Lax

# Database
DATABASE_URL=
# Example:
# DATABASE_URL=postgresql://tallerdeotto:change-me@127.0.0.1:5432/tallerdeotto

# Alternative explicit variables:
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# PostgreSQL example:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=tallerdeotto
# DB_USER=tallerdeotto
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com
EMAIL_TIMEOUT=20
